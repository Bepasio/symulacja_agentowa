#### 7. `SimulationGame.java` (Widok w LibGDX)

Twój zmodyfikowany kod okna gry. Zajmuje się rysowaniem kafelków terenu z ASCII, automatycznie przelicza oś Y, żeby miasto stało prosto, oraz rysuje agentów jako kółka.

```java
package pl.butelkomat.simulation.gui;

import com.badlogic.gdx.ApplicationAdapter;
import com.badlogic.gdx.Gdx;
import com.badlogic.gdx.graphics.Color;
import com.badlogic.gdx.graphics.GL20;
import com.badlogic.gdx.graphics.OrthographicCamera;
import com.badlogic.gdx.graphics.glutils.ShapeRenderer;
import pl.butelkomat.simulation.agents.Agent;
import pl.butelkomat.simulation.agents.Consumer;
import pl.butelkomat.simulation.engine.SimulationEngine;
import pl.butelkomat.simulation.infrastructure.Butelkomat;
import pl.butelkomat.simulation.infrastructure.TrashBin;
import pl.butelkomat.simulation.world.WorldMap;
import pl.butelkomat.simulation.world.Zone;

public class SimulationGame extends ApplicationAdapter {
    private SimulationEngine engine;
    private ShapeRenderer shapeRenderer;
    private OrthographicCamera camera;

    private final int TILE_SIZE = 12; // Zwiększyłem delikatnie, żeby Wrocław był wyraźniejszy

    @Override
    public void create() {
        // 1. Inicjalizacja świata (Szerokość 89, Wysokość 25 zgodnie z plikiem ASCII)
        WorldMap worldMap = new WorldMap(89, 25);
        worldMap.loadMapFromAscii("cfg/wroclaw_map.txt"); // Wrzuć plik tekstowy do folderu assets/cfg/

        // Konfiguracja stref z Twojego Maina
        worldMap.addZone(new Zone("Wyspa Słodowa", 7, 18, 3, 7, 2.0));
        worldMap.addZone(new Zone("Ogród Botaniczny", 32, 63, 0, 6, 2.0));
        worldMap.addZone(new Zone("Plac Grunwaldzki", 54, 89, 7, 14, 1.5));
        worldMap.addZone(new Zone("Politechnika Wrocławska", 50, 89, 15, 25, 1.2));

        // Losowy wybór infrastruktury (np. chcemy 6 butelkomatów i 12 koszy ze slotów)
        worldMap.configureInfrastructure(6, 12, 100, 10, 50);

        engine = new SimulationEngine(worldMap);
        engine.spawnAgents(15, 4); // Tworzymy 15 Konsumentów i 4 Zbieraczy

        // Kontrola czasu z GUI (przykład: przyspieszenie x5)
        engine.getTimeManager().setSpeedMultiplier(5.0f);

        camera = new OrthographicCamera();
        camera.setToOrtho(false, Gdx.graphics.getWidth(), Gdx.graphics.getHeight());
        shapeRenderer = new ShapeRenderer();
    }

    @Override
    public void render() {
        engine.update(Gdx.graphics.getDeltaTime());
        camera.update();

        Gdx.gl.glClearColor(0.05f, 0.05f, 0.05f, 1);
        Gdx.gl.glClear(GL20.GL_COLOR_BUFFER_BIT);

        shapeRenderer.setProjectionMatrix(camera.combined);
        shapeRenderer.begin(ShapeRenderer.ShapeType.Filled);

        WorldMap map = engine.getMap();
        int mapHeight = map.getHeight();

        // KROK 1: Rysowanie podłoża (Tereny z pliku ASCII)
        for (int y = 0; y < mapHeight; y++) {
            for (int x = 0; x < map.getWidth(); x++) {
                float renderX = x * TILE_SIZE;
                float renderY = (mapHeight - 1 - y) * TILE_SIZE; // Odwrócenie osi Y

                WorldMap.TileType tile = map.getTileType(x, y);
                if (tile == WorldMap.TileType.WATER) shapeRenderer.setColor(Color.BLUE);
                else if (tile == WorldMap.TileType.GRASS) shapeRenderer.setColor(Color.FOREST);
                else if (tile == WorldMap.TileType.PATH) shapeRenderer.setColor(Color.CORAL);
                else shapeRenderer.setColor(Color.DARK_GRAY); // Przeszkody / Tekst

                shapeRenderer.rect(renderX, renderY, TILE_SIZE, TILE_SIZE);
            }
        }

        // KROK 2: Rysowanie aktywnej infrastruktury
        shapeRenderer.setColor(Color.GREEN);
        for (Butelkomat b : map.getButelkomats()) {
            float rx = b.getPosition().getX() * TILE_SIZE;
            float ry = (mapHeight - 1 - b.getPosition().getY()) * TILE_SIZE;
            shapeRenderer.rect(rx + 2, ry + 2, TILE_SIZE - 4, TILE_SIZE - 4);
        }

        shapeRenderer.setColor(Color.LIGHT_GRAY);
        for (TrashBin t : map.getTrashBins()) {
            float rx = t.getPosition().getX() * TILE_SIZE;
            float ry = (mapHeight - 1 - t.getPosition().getY()) * TILE_SIZE;
            shapeRenderer.rect(rx + 2, ry + 2, TILE_SIZE - 4, TILE_SIZE - 4);
        }

        // KROK 3: Rysowanie Agentów (Kółka)
        for (Agent agent : map.getAgents()) {
            float rx = agent.getPosition().getX() * TILE_SIZE + (TILE_SIZE / 2f);
            float ry = (mapHeight - 1 - agent.getPosition().getY()) * TILE_SIZE + (TILE_SIZE / 2f);

            if (agent instanceof Consumer) shapeRenderer.setColor(Color.YELLOW);
            else shapeRenderer.setColor(Color.CYAN);

            shapeRenderer.circle(rx, ry, TILE_SIZE / 3f);
        }

        shapeRenderer.end();
    }

    @Override
    public void dispose() { shapeRenderer.dispose(); }
}

```

