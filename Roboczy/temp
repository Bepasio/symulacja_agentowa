### PAKIET: `pl.butelkomat.simulation.world`

#### 3. `WorldMap.java` (Zaktualizowana o parser ASCII i dynamiczne sloty)

Teraz klasa wczytuje Twój plik, zapamiętuje ukryte punkty `B` i `K`, a metoda `configureInfrastructure` losuje ich aktywację na podstawie wyboru z GUI.

```java
package pl.butelkomat.simulation.world;

import com.badlogic.gdx.Gdx;
import com.badlogic.gdx.files.FileHandle;
import pl.butelkomat.simulation.agents.Agent;
import pl.butelkomat.simulation.infrastructure.Butelkomat;
import pl.butelkomat.simulation.infrastructure.TrashBin;

import java.io.BufferedReader;
import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

public class WorldMap {
    public enum TileType { PATH, WATER, GRASS, OBSTACLE }

    private int width;
    private int height;
    private TileType[][] terrainGrid;

    // Listy potencjalnych punktów pobranych z ASCII
    private final List<Position> potentialButelkomatSlots = new ArrayList<>();
    private final List<Position> potentialTrashBinSlots = new ArrayList<>();

    // Aktywne obiekty (to je rysujemy i z nimi wchodzimy w interakcję)
    private final ArrayList<Butelkomat> butelkomats = new ArrayList<>();
    private final ArrayList<TrashBin> trashBins = new ArrayList<>();
    private final ArrayList<Zone> zones = new ArrayList<>();
    private final ArrayList<Agent> agents = new ArrayList<>();

    public WorldMap(int width, int height) {
        this.width = width;
        this.height = height;
        this.terrainGrid = new TileType[height][width];
    }

    public void loadMapFromAscii(String internalPath) {
        potentialButelkomatSlots.clear();
        potentialTrashBinSlots.clear();

        FileHandle file = Gdx.files.internal(internalPath);
        BufferedReader reader = new BufferedReader(file.reader());

        try {
            String line;
            int y = 0;
            while ((line = reader.readLine()) != null && y < height) {
                for (int x = 0; x < line.length() && x < width; x++) {
                    char c = line.charAt(x);

                    if (c == '~') {
                        terrainGrid[y][x] = TileType.WATER;
                    } else if (c == '.' || c == '*') {
                        terrainGrid[y][x] = TileType.GRASS;
                    } else if (c == '=' || c == '|' || c == '/' || c == '\\' || c == '-') {
                        terrainGrid[y][x] = TileType.PATH;
                    } else if (c == 'B') {
                        terrainGrid[y][x] = TileType.PATH;
                        potentialButelkomatSlots.add(new Position(x, y));
                    } else if (c == 'K') {
                        terrainGrid[y][x] = TileType.PATH;
                        potentialTrashBinSlots.add(new Position(x, y));
                    } else {
                        terrainGrid[y][x] = TileType.OBSTACLE; // Tekst np. "Odra" blokuje ruch
                    }
                }
                y++;
            }
            reader.close();
        } catch (Exception e) {
            System.out.println("Błąd wczytywania mapy ASCII: " + e.getMessage());
        }
    }

    // Wywoływane po ustawieniu suwaków w GUI
    public void configureInfrastructure(int bCount, int tCount, int bCap, int paper, int tCap) {
        butelkomats.clear();
        trashBins.clear();

        List<Position> shuffledB = new ArrayList<>(potentialButelkomatSlots);
        List<Position> shuffledT = new ArrayList<>(potentialTrashBinSlots);
        Collections.shuffle(shuffledB);
        Collections.shuffle(shuffledT);

        for (int i = 0; i < Math.min(bCount, shuffledB.size()); i++) {
            butelkomats.add(new Butelkomat(bCap, paper, shuffledB.get(i)));
        }
        for (int i = 0; i < Math.min(tCount, shuffledT.size()); i++) {
            trashBins.add(new TrashBin(tCap, shuffledT.get(i)));
        }
    }

    public boolean isWalkable(int x, int y) {
        if (x < 0 || x >= width || y < 0 || y >= height) return false;
        return terrainGrid[y][x] == TileType.PATH; // Agenci chodzą tylko po ścieżkach/mostach
    }

    public double getMultiplierAt(Position position) {
        for (Zone zone : zones) {
            if (zone.isInZone(position)) return zone.getMultiplier();
        }
        return 1.0;
    }

    // Twoje dotychczasowe metody i gettery
    public int getWidth() { return width; }
    public int getHeight() { return height; }
    public ArrayList<Butelkomat> getButelkomats() { return butelkomats; }
    public ArrayList<TrashBin> getTrashBins() { return trashBins; }
    public ArrayList<Agent> getAgents() { return agents; }
    public void addZone(Zone zone) { zones.add(zone); }
    public TileType getTileType(int x, int y) { return terrainGrid[y][x]; }
}

```

