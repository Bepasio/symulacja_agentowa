#### 6. `Collector.java` (Zbieracz – opróżnia kosze i oddaje butelki do butelkomatu)

```java
package pl.butelkomat.simulation.agents;

import pl.butelkomat.simulation.infrastructure.Butelkomat;
import pl.butelkomat.simulation.infrastructure.TrashBin;
import pl.butelkomat.simulation.item.Bottle;
import pl.butelkomat.simulation.world.Position;
import pl.butelkomat.simulation.world.WorldMap;

public class Collector extends Agent {
    private boolean headingToButelkomat = false;

    public Collector(Position position, int backpackCapacity) {
        super(position, backpackCapacity);
    }

    @Override
    public void step(boolean canMoveThisTick, WorldMap worldMap) {
        if (!canMoveThisTick) return;

        // Jeśli plecak pełen, zmiana priorytetu na Butelkomat
        if (bottles.size() >= backpackCapacity) headingToButelkomat = true;
        if (bottles.isEmpty()) headingToButelkomat = false;

        if (headingToButelkomat) {
            // Idź do Butelkomatu oddać zwrotne butelki
            Butelkomat b = findClosestButelkomat(worldMap);
            if (b != null) {
                if (isAdjacentTo(b.getPosition())) {
                    b.processDeposit(this.bottles); // Przetwarzanie kaucji (usuwa zwrotne z listy zbieracza)
                    if (!bottles.isEmpty()) bottles.clear(); // Niezwrotne wyrzuca
                } else {
                    moveTowards(b.getPosition(), worldMap);
                }
            }
        } else {
            // Idź opróżniać kosze ze śmieci
            TrashBin bin = findFullestBin(worldMap);
            if (bin != null && bin.getCurrentFillLevel() > 0) {
                if (isAdjacentTo(bin.getPosition())) {
                    Bottle taken = bin.takeBottle();
                    if (taken != null) bottles.add(taken);
                } else {
                    moveTowards(bin.getPosition(), worldMap);
                }
            }
        }
    }

    private TrashBin findFullestBin(WorldMap map) {
        TrashBin fullest = null;
        for (TrashBin t : map.getTrashBins()) {
            if (fullest == null || t.getCurrentFillLevel() > fullest.getCurrentFillLevel()) fullest = t;
        }
        return fullest;
    }

    private Butelkomat findClosestButelkomat(WorldMap map) {
        if (map.getButelkomats().isEmpty()) return null;
        return map.getButelkomats().get(0);
    }
}

